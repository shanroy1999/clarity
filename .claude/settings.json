{
    "env": {
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}",
        "CLARITY_HOOK_SECRET": "${CLARITY_HOOK_SECRET}"
    },
    "mcpServers": {
        "google-calendar": {
            "type": "url",
            "url": "https://mcp.googleapis.com/calendar/v3",
            "transport": "http",
            "scope": "project",
            "auth": {
                "type": "oauth2",
                "clientId": "${GOOGLE_CLIENT_ID}",
                "clientSecret": "${GOOGLE_CLIENT_SECRET}",
                "scopes": [
                    "https://www.googleapis.com/auth/calendar.readonly"
                ]
            }
        },
        "gmail": {
            "type": "url",
            "url": "https://mcp.googleapis.com/gmail/v1",
            "transport": "http",
            "scope": "project",
            "auth": {
                "type": "oauth2",
                "clientId": "${GOOGLE_CLIENT_ID}",
                "clientSecret": "${GOOGLE_CLIENT_SECRET}",
                "scopes": [
                    "https://www.googleapis.com/auth/gmail.readonly"
                ]
            }
        },
        "todoist": {
            "type": "url",
            "url": "https://mcp.todoist.com/mcp",
            "transport": "http",
            "scope": "project",
            "auth": {
                "type": "bearer",
                "token": "${TODOIST_API_TOKEN}"
            }
        },
        "clarity-financial": {
            "type": "stdio",
            "command": "python3",
            "args": [
                "-m",
                "backend.mcp_servers.financial"
            ],
            "scope": "project",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        }
    },
    "hooks": {
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/session-start.sh"
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/validate-agent-structure.sh"
                    }
                ]
            },
            {
                "matcher": "mcp__*",
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/mcp-access-guard.sh"
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/run-tests-on-edit.sh"
                    }
                ]
            },
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/audit-logger.sh",
                        "async": true
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/quality-gate.sh",
                        "async": false
                    },
                    {
                        "type": "http",
                        "url": "http://localhost:8000/api/hooks/session-stop",
                        "method": "POST",
                        "headers": {
                            "X-Clarity-Secret": "${CLARITY_HOOK_SECRET}"
                        },
                        "async": true
                    }
                ]
            }
        ],
        "SubagentStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/agent-timer.sh",
                        "async": true
                    }
                ]
            }
        ],
        "SubagentStop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/agent-timer.sh",
                        "async": true
                    }
                ]
            }
        ],
        "Notification": []
    }
}